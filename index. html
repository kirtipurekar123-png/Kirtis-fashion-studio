<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Kirti's Fashion Studio</title>
    <style>
        /* CSS Styling for Elegant Look */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        body {
            background-color: #fcf8f9;
            color: #333;
        }

        /* Header Section */
        header {
            background-color: #ffffff;
            padding: 30px 20px;
            text-align: center;
            border-bottom: 3px solid #ff6699;
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.05);
        }

        header h1 {
            font-size: 3rem;
            color: #ff6699; /* Beautiful Pink */
            font-weight: 700;
            letter-spacing: 2px;
            text-transform: uppercase;
            margin-bottom: 5px;
        }

        header p {
            font-size: 1.1rem;
            color: #555555; /* Small stylish text */
            font-style: italic;
            letter-spacing: 1px;
        }

        /* Navigation Menu */
        nav {
            margin-top: 15px;
        }

        nav a {
            text-decoration: none;
            color: #333;
            font-weight: 600;
            margin: 0 15px;
            transition: color 0.3s;
        }

        nav a:hover {
            color: #ff6699;
        }

        /* Main Content Hero Area */
        .hero {
            max-width: 1000px;
            margin: 50px auto;
            padding: 40px 20px;
            background-color: #ffffff;
            border-radius: 10px;
            text-align: center;
            box-shadow: 0 4px 15px rgba(0,0,0,0.05);
        }

        .hero h2 {
            color: #222;
            margin-bottom: 15px;
            font-size: 2rem;
        }

        .hero p {
            color: #666;
            line-height: 1.6;
            font-size: 1.2rem;
        }
    </style>
</head>
<body>

    <!-- Header Section -->
    <header>
        <h1>Kirti's Fashion Studio</h1>
        <p>Your Style, Our Fashion</p>
        
        <!-- Navigation Menu -->
        <nav>
            <a href="#">Home</a>
            <a href="#">About Us</a>
            <a href="#">Services</a>
            <a href="#">Contact</a>
        </nav>
    </header>

    <!-- Main Section (For Future Info) -->
    <section class="hero">
        <h2>Welcome to Kirti's Fashion Studio</h2>
        <p>This is where we bring your dream designs to life. Stay tuned for our latest fashion collections, custom tailoring services, and gorgeous ladies' dresses!</p>
    </section>

</body>
</html>
